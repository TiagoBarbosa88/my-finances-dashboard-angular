# ─── Supabase (Angular — frontend) ───────────────────────────────────────────
# Local: use estes nomes no .env
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_SUA_CHAVE_AQUI
SUPABASE_JWKS_URL=https://SEU_PROJECT_ID.supabase.co/auth/v1/.well-known/jwks.json

# Vercel + integração Supabase também injeta (mesmo efeito):
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_ANON_KEY=

# ⚠️  NUNCA no Angular — só servidor / Edge Functions / Vercel serverless
SUPABASE_SECRET_KEY=sb_secret_SUA_CHAVE_AQUI
SUPABASE_SERVICE_ROLE_KEY=

# ─── API local (JSON Server — não funciona no deploy estático Vercel) ────────
API_URL=http://localhost:3000

# ─── Brapi (cotações) — adicione manualmente na Vercel → Settings → Env ───────
BRAPI_API_ROOT=https://brapi.dev/api
BRAPI_BASE_URL=https://brapi.dev/api/v2/stocks
BRAPI_TOKEN=SUA_CHAVE_BRAPI_AQUI

# ─── App ─────────────────────────────────────────────────────────────────────
# Em produção (Vercel) vira false automaticamente se VERCEL_ENV=production
BYPASS_AUTH=true
