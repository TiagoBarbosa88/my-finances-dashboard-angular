# ─── Supabase (Angular — frontend) ───────────────────────────────────────────
# ⚠️  USE O MESMO PROJETO em local, Vercel e onde rodou o SQL do schema.
# Projeto com schema + usuário admin: my-finances → sakwtegkqzgpphmcsrac
# (NÃO use nuxueulwvkhbazzwbsza se o Auth/user foi criado no outro projeto.)
SUPABASE_URL=https://sakwtegkqzgpphmcsrac.supabase.co

# Preferir JWT anon (Settings → API → anon public) — mais estável no Auth:
SUPABASE_ANON_KEY=eyJ...SUA_ANON_KEY...
# Opcional (fallback):
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_JWKS_URL=https://sakwtegkqzgpphmcsrac.supabase.co/auth/v1/.well-known/jwks.json

# Vercel + integração Supabase injeta (mesmo efeito se apontar pro projeto certo):
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ⚠️  NUNCA no Angular — só servidor / Edge Functions / Vercel serverless
SUPABASE_SECRET_KEY=sb_secret_SUA_CHAVE_AQUI
SUPABASE_SERVICE_ROLE_KEY=

# ─── API local (JSON Server — não funciona no deploy estático Vercel) ────────
API_URL=http://localhost:3000

# ─── Brapi (cotações) — adicione manualmente na Vercel → Settings → Env ───────
BRAPI_API_ROOT=https://brapi.dev/api
BRAPI_BASE_URL=https://brapi.dev/api/v2/stocks
BRAPI_TOKEN=SUA_CHAVE_BRAPI_AQUI

# ─── App ─────────────────────────────────────────────────────────────────────
# Em produção (Vercel) vira false automaticamente se VERCEL_ENV=production
BYPASS_AUTH=true
