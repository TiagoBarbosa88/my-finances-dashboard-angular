# ─── Supabase (frontend usa URL + publishable key) ───────────────────────────
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_SUA_CHAVE_AQUI
SUPABASE_JWKS_URL=https://SEU_PROJECT_ID.supabase.co/auth/v1/.well-known/jwks.json

# ⚠️  SECRET — apenas backend/Edge Functions. NUNCA no Angular.
SUPABASE_SECRET_KEY=sb_secret_SUA_CHAVE_AQUI

# ─── API local (JSON Server) ─────────────────────────────────────────────────
API_URL=http://localhost:3000

# ─── Brapi (cotações) ────────────────────────────────────────────────────────
BRAPI_API_ROOT=https://brapi.dev/api
BRAPI_BASE_URL=https://brapi.dev/api/v2/stocks
BRAPI_TOKEN=SUA_CHAVE_BRAPI_AQUI

# ─── App ─────────────────────────────────────────────────────────────────────
BYPASS_AUTH=true
